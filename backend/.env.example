# --- Server ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Database (Prisma + MySQL) ---
DATABASE_URL="mysql://root:rootpw@localhost:3306/leadradius"

# --- Auth ---
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10

# --- Google Places ---
GOOGLE_API_KEY=
USE_LIVE_PLACES=false

# --- Redis (BullMQ + cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Cache TTL (seconds) ---
CACHE_TTL_SECONDS=43200

# --- Logging ---
LOG_LEVEL=info
