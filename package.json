{
  "name": "leadradius-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "install:all": "npm install && cd backend && npm install",
    "backend:dev": "cd backend && npm run dev",
    "backend:worker": "cd backend && npm run worker",
    "backend:migrate": "cd backend && npx prisma migrate deploy",
    "dev:all": "concurrently -n web,api,worker -c green,cyan,yellow --kill-others-on-fail \"npm run dev\" \"npm run backend:dev\" \"npm run backend:worker\""
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.5",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.460.0",
    "motion": "^12.38.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
