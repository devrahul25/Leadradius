# --- Backend integration -------------------------------------------------
# Point the frontend at the running backend. Leave blank to use local mocks.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# --- Direct Google integration (NOT recommended in production) -----------
# Used only by the legacy lib/google-places.ts client-side fallback when
# NEXT_PUBLIC_API_URL is unset. Real apps should always proxy via backend.
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_USE_LIVE_PLACES=false
